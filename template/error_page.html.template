<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{code}} {{message}}</title>
    <style>
        body {
            background-color: #ffffff;
            color: #333333;
            font-family: "Helvetica Neue", Arial, "Hiragino Kaku Gothic ProN", "Hiragino Sans", Meiryo, sans-serif;
            margin: 0;
            padding: 0;
            text-align: center;
            line-height: 1.5;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        :root {
            --bg: #ffffff;
            --fg: #333333;
            --muted: #666666;
            --accent: #0066cc;
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --bg: #1a1a1a;
                --fg: #eeeeee;
                --muted: #aaaaaa;
                --accent: #4da6ff;
            }

            body {
                background-color: #1a1a1a;
                color: #eeeeee;
            }
        }

        .container {
            padding: 40px 20px;
            max-width: 500px;
            margin: 0 auto;
        }

        h1 {
            font-size: 80px;
            font-size: 5rem;
            margin: 0;
            font-weight: bold;
            color: #0066cc;
            color: var(--accent);
            line-height: 1;
        }

        h2 {
            font-size: 24px;
            font-size: 1.5rem;
            margin: 10px 0 20px;
        }

        hr {
            border: 0;
            border-top: 1px solid #cccccc;
            border-top: 1px solid var(--muted);
            opacity: 0.3;
            margin: 30px 0;
        }

        .server-info {
            font-size: 12px;
            font-size: 0.75rem;
            color: #666666;
            color: var(--muted);
            font-family: Consolas, Monaco, "Lucida Console", monospace;
        }
    </style>

</head>

<body>
    <div class="container">
        <h1>{{code}}</h1>
        <h2>{{message}}</h2>
        <hr>
        <div class="server-info">
            Server: {{server}}<br>
            Time: {{time}}
        </div>
    </div>
</body>

</html>
